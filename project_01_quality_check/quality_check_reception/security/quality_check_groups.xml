<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="quality_check_reception_category_quality_check" model="ir.module.category">
    <field name="name">Quality Check</field>
    <field name="sequence">20</field>
</record>

<record id="group_quality_controller" model="res.groups">
    <field name="name">Contrôleur de Qualité</field>
    <field name="category_id" ref="quality_check_reception_category_quality_check"/>
</record>

<record id="group_quality_manager " model="res.groups">
    <field name="name">Responsable Qualité</field>
    <field name="category_id" ref="quality_check_reception_category_quality_check"/>
    <field name="implied_ids" eval="[(4, ref('group_quality_controller'))]"/>
</record>

<record id="group_quality_admin" model="res.groups">
    <field name="name">Administrateur Qualité</field>
    <field name="category_id" ref="quality_check_reception_category_quality_check"/>
    <field name="implied_ids" eval="[(4, ref('group_quality_manager '))]"/>
</record>

</odoo>
