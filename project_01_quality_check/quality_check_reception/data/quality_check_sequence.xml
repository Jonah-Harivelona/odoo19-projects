<?xml version='1.0' encoding="utf-8"?>
<odoo>
<data noupdate="1">  

<record id="seq_quality_check" model="ir.sequence">
    <field name="name">Quality check sequence</field>
    <field name='code'>quality.check</field>
    <field name='prefix'>QC/%(year)s</field>
    <field name='padding'>4</field>
    <field name='company_id' eval='False'/>
</record>
    
<record id="seq_quality_nonconformity" model="ir.sequence">
    <field name="name">Quality Non-Conformity Sequence</field>
    <field name="code">quality.nonconformity</field>
    <field name="prefix">NC/%(year)s/</field>
    <field name="padding">4</field>
    <field name="company_id" eval="False"/>
</record>

</data>
</odoo>

